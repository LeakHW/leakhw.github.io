---
// index.astro
interface Props {
  studentCount?: number;
}

const { studentCount = 27910 } = Astro.props;
const formattedCount = studentCount.toLocaleString();

// CONFIGURATION
const showEarlyNotice = true; // Toggle this to show/hide the early development notice

// Default values for initial load
let latestVersion = 'Loading...';
let downloadUrl = 'https://github.com/LeakHW/Extension/releases/latest';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leak - Your Homework Helper Suite</title>
    <link rel="icon" type="image/png" href="https://raw.githubusercontent.com/LeakHW/.github/refs/heads/main/assets/leakhw.png">
</head>
<body>
    {showEarlyNotice && (
        <div class="early-notice">
            <div class="notice-content">
                <span class="notice-icon">⚠️</span>
                <p>Leak is in early stages of development. Nothing is near finished yet and a lot is subject to change.</p>
            </div>
        </div>
    )}

    <div class="gradient-bg"></div>
    <div class="gradient-orb gradient-orb-1"></div>
    <div class="gradient-orb gradient-orb-2"></div>
    <div class="gradient-orb gradient-orb-3"></div>
    
    <nav>
        <div class="logo">
            <img src="https://raw.githubusercontent.com/LeakHW/.github/refs/heads/main/assets/leakhw.png" alt="Leak Logo" width="32" height="32">
            <span>Leak</span>
        </div>
        <div class="nav-links">
            <a href="#download">Download</a>
            <a href="https://github.com/LeakHW" target="_blank">GitHub</a>
        </div>
    </nav>

    <main id="home">
        <h1><span class="brand">Leak:</span> YOUR Homework Helper Suite</h1>
        <p class="subtitle">
            Stuck on homework? Our powerful browser extension helps you understand complex problems,<br>
            check your work, and improve your grades.
        </p>
        <div class="cta-buttons">
            <a href="#download" class="get-started">Download Extension →</a>
            <a href="https://github.com/LeakHW" target="_blank" class="github-btn">View on GitHub</a>
        </div>
        <p class="student-count">Make your <span>homework experience</span> better</p>
    </main>

    <section id="download" class="download-section">
        <div class="download-container">
            <h2>Download Leak Extension</h2>
            <p class="download-subtitle">Get the latest version of our Chrome extension</p>
            
            <div class="download-card">
                <div class="download-info">
                    <img src="https://raw.githubusercontent.com/LeakHW/.github/refs/heads/main/assets/leakhw.png" alt="Leak Logo" width="64" height="64">
                    <div>
                        <h3>Leak Extension</h3>
                        <p class="version">Latest Version: <span id="latest-version">{latestVersion}</span></p>
                    </div>
                </div>

                <div class="testing-notice">
                    <p><strong>Note:</strong> This extension is currently for <strong>testing only</strong>. Please report any bugs, feature requests, or problems on our <a href="https://github.com/LeakHW/Extension/issues" target="_blank">GitHub Issues</a> page.</p>
                </div>
                
                <a href={downloadUrl} id="download-link" class="download-btn" download>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 3V16M12 16L16 12M12 16L8 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M3 17V19C3 20.1046 3.89543 21 5 21H19C20.1046 21 21 20.1046 21 19V17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    Download for Chrome
                </a>

                <div class="install-steps">
                    <h4>Installation Instructions:</h4>
                    <ol>
                        <li>Download the extension file</li>
                        <li>Open Chrome and go to <code>chrome://extensions/</code></li>
                        <li>Enable "Developer mode" in the top right</li>
                        <li>Drag and drop the downloaded file or click "Load unpacked"</li>
                        <li>The Leak extension is now installed!</li>
                    </ol>
                </div>
            </div>

            <div class="github-link">
                <p>Want to see the source code or report an issue?</p>
                <a href="https://github.com/LeakHW/Extension/releases" target="_blank" class="view-releases">
                    View all releases on GitHub →
                </a>
            </div>
        </div>
    </section>

    <script>
        async function fetchLatestRelease() {
            const versionEl = document.getElementById('latest-version');
            const downloadLink = document.getElementById('download-link') as HTMLAnchorElement;

            try {
                const response = await fetch('https://api.github.com/repos/LeakHW/Extension/releases/latest');
                if (response.ok) {
                    const data = await response.json();
                    if (versionEl) versionEl.textContent = data.tag_name;
                    
                    const extensionAsset = data.assets.find((asset: any) => 
                        asset.name === 'extension.zip' || asset.name.endsWith('.zip') || asset.name.endsWith('.crx')
                    );
                    
                    if (extensionAsset && downloadLink) {
                        downloadLink.href = extensionAsset.browser_download_url;
                    }
                } else {
                    if (versionEl) versionEl.textContent = 'v1.0.0';
                }
            } catch (error) {
                console.error('Failed to fetch latest release:', error);
                if (versionEl) versionEl.textContent = 'v1.0.0';
            }
        }

        fetchLatestRelease();
    </script>
</body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #020617;
        color: #f8fafc;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
    }

    .early-notice {
        background: rgba(30, 58, 138, 0.4);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(59, 130, 246, 0.2);
        padding: 0.75rem 1rem;
        position: sticky;
        top: 0;
        z-index: 100;
        text-align: center;
    }

    .notice-content {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .notice-content p {
        font-size: 0.875rem;
        color: #bfdbfe;
        font-weight: 500;
    }

    .notice-icon {
        font-size: 1rem;
    }

    .gradient-bg {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
            radial-gradient(circle at 50% -20%, rgba(30, 58, 138, 0.3), transparent 70%),
            radial-gradient(circle at 0% 100%, rgba(15, 23, 42, 1), transparent),
            #020617;
        pointer-events: none;
        z-index: 0;
    }

    .gradient-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.2;
        pointer-events: none;
        z-index: 0;
        animation: float 25s infinite ease-in-out;
    }

    .gradient-orb-1 {
        width: 800px;
        height: 800px;
        background: radial-gradient(circle, #1e40af, transparent 70%);
        top: -300px;
        right: -200px;
        animation-delay: 0s;
    }

    .gradient-orb-2 {
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, #3b82f6, transparent 70%);
        bottom: -200px;
        left: -150px;
        animation-delay: -12s;
    }

    .gradient-orb-3 {
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, #60a5fa, transparent 70%);
        top: 40%;
        left: 30%;
        animation-delay: -5s;
        opacity: 0.1;
    }

    @keyframes float {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(50px, -50px) scale(1.05);
        }
        66% {
            transform: translate(-30px, 30px) scale(0.95);
        }
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 3rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
    }

    .logo img {
        border-radius: 10px;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .nav-links a {
        color: #94a3b8;
        text-decoration: none;
        transition: all 0.3s;
        font-weight: 500;
        font-size: 0.95rem;
    }

    .nav-links a:hover {
        color: #3b82f6;
    }

    main {
        text-align: center;
        padding: 8rem 2rem;
        max-width: 1000px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    h1 {
        font-size: 4.5rem;
        font-weight: 800;
        margin-bottom: 2rem;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: #f8fafc;
    }

    .brand {
        background: linear-gradient(135deg, #60a5fa, #2563eb);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
    }

    .subtitle {
        color: #94a3b8;
        font-size: 1.25rem;
        line-height: 1.7;
        margin-bottom: 3.5rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-buttons {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
        margin-bottom: 3rem;
    }

    .get-started, .github-btn {
        padding: 1rem 2.5rem;
        border-radius: 0.75rem;
        font-size: 1.125rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

    .get-started {
        background: #2563eb;
        color: white;
        border: none;
        box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
    }

    .get-started:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -5px rgba(37, 99, 235, 0.5);
    }

    .github-btn {
        background: rgba(30, 41, 59, 0.5);
        backdrop-filter: blur(10px);
        color: #f8fafc;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .github-btn:hover {
        background: rgba(51, 65, 85, 0.6);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
    }

    .student-count {
        color: #64748b;
        font-size: 1rem;
    }

    .student-count span {
        color: #3b82f6;
        font-weight: 700;
    }

    /* Download Section */
    .download-section {
        position: relative;
        z-index: 10;
        padding: 6rem 2rem;
        max-width: 1000px;
        margin: 0 auto;
    }

    .download-container {
        text-align: center;
    }

    .download-container h2 {
        font-size: 3rem;
        margin-bottom: 1.25rem;
        font-weight: 800;
        color: #f8fafc;
    }

    .download-subtitle {
        color: #94a3b8;
        font-size: 1.25rem;
        margin-bottom: 4rem;
    }

    .download-card {
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.1);
        border-radius: 1.5rem;
        padding: 4rem;
        margin-bottom: 3rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .download-info {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 3rem;
        text-align: left;
    }

    .download-info img {
        border-radius: 16px;
    }

    .download-info h3 {
        font-size: 2rem;
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .version {
        color: #3b82f6;
        font-size: 1.125rem;
        font-weight: 600;
    }

    .testing-notice {
        background: rgba(30, 58, 138, 0.2);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 0.75rem;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
        text-align: left;
    }

    .testing-notice p {
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.5;
        margin: 0;
    }

    .testing-notice strong {
        color: #60a5fa;
    }

    .testing-notice a {
        color: #3b82f6;
        text-decoration: none;
        font-weight: 600;
    }

    .testing-notice a:hover {
        text-decoration: underline;
        color: #60a5fa;
    }

    .download-btn {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: white;
        border: none;
        padding: 1.25rem 3rem;
        border-radius: 1rem;
        font-size: 1.25rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        box-shadow: 0 15px 35px -5px rgba(37, 99, 235, 0.4);
        margin-bottom: 3rem;
    }

    .download-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 45px -5px rgba(37, 99, 235, 0.5);
    }

    .install-steps {
        background: rgba(2, 6, 23, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        padding: 2rem;
        text-align: left;
    }

    .install-steps h4 {
        margin-bottom: 1.5rem;
        color: #f8fafc;
        font-size: 1.25rem;
        font-weight: 600;
    }

    .install-steps ol {
        padding-left: 1.5rem;
        color: #94a3b8;
    }

    .install-steps li {
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .install-steps code {
        background: rgba(37, 99, 235, 0.1);
        color: #60a5fa;
        padding: 0.2rem 0.4rem;
        border-radius: 0.4rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.9em;
    }

    .github-link {
        margin-top: 2rem;
    }

    .github-link p {
        color: #64748b;
        margin-bottom: 1rem;
    }

    .view-releases {
        color: #3b82f6;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
    }

    .view-releases:hover {
        color: #60a5fa;
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        h1 { font-size: 3rem; }
        nav { padding: 1.5rem; }
        .nav-links { display: none; }
        .download-card { padding: 2rem; }
        .download-info { flex-direction: column; text-align: center; }
    }

    /* iOS Safari fix for scroll breaking */
    @supports (-webkit-touch-callout: none) {
        .gradient-orb {
            position: absolute !important; /* stop fixed repaint bug */
            filter: blur(50px) !important; /* reduce heavy blur */
            animation: none !important; /* disable animation causing glitches */
            transform: translateZ(0);
            will-change: transform;
        }
    
        .gradient-bg {
            position: absolute !important; /* prevent layered fixed issues */
        }
    }
</style>